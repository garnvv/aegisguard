{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/login(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/logout(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/register(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/dashboard(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/admin(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/social/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/verify-otp(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/resend-otp(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "/(.*\\.js)",
      "dest": "/frontend/dist/$1"
    },
    {
      "src": "/(.*\\.css)",
      "dest": "/frontend/dist/$1"
    },
    {
      "src": "/(.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.gif|.*\\.svg|.*\\.ico|.*\\.woff|.*\\.woff2|.*\\.ttf|.*\\.map|.*\\.webp)",
      "dest": "/frontend/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
